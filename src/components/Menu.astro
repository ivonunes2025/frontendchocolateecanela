---
import axios from 'axios';

interface Produto {
    id: number;
    Nome: string;
    Categoria: string;
    Preco: number | string;
    Descricao?: string;
}

const strapiUrl = "http://localhost:1337";
let rawItems: any[] = [];
let categorias: string[] = [];

try {
    const response = await axios.get(`${strapiUrl}/api/produto-menus?populate=*&pagination[pageSize]=100`);
    rawItems = response.data.data;
    
    const getAttr = (item: any) => {
        if (!item) return {};
        const data = item.attributes || item;
        return {
            Nome: data.Nome || data.NOME,
            Categoria: data.Categoria || data.CATEGORIA,
            Preco: data.Preco || data.PRECO,
            Descricao: data.Descricao || data.DESCRICAO
        };
    };
    
    const allCats = rawItems.map((item: any) => getAttr(item).Categoria);
    categorias = [...new Set(allCats)]
        .filter((cat): cat is string => typeof cat === 'string' && cat.trim() !== '')
        .sort((a, b) => a.localeCompare(b, 'pt'));
} catch (error: any) {
    console.error("Erro ao ligar ao Strapi.", error.message);
}

const catMeta: Record<string, { emoji: string; cor: string }> = {
    'Cafetaria':  { emoji: '☕', cor: '#8B5E3C' },
    'Crepes':     { emoji: '🥞', cor: '#C07D3E' },
    'Waffles':    { emoji: '🧇', cor: '#B8722A' },
    'Iogurtes':   { emoji: '🥣', cor: '#9B7B5A' },
    'Torradas':   { emoji: '🍞', cor: '#A0704C' },
    'Tostas':     { emoji: '🥪', cor: '#7A5C47' },
    'Sumos':      { emoji: '🥤', cor: '#5E8B6E' },
    'Bolos':      { emoji: '🍰', cor: '#C07D3E' },
    'Padaria':    { emoji: '🥖', cor: '#8B7355' },
};

const getMeta = (cat: string) => catMeta[cat] || { emoji: '✨', cor: '#C07D3E' };
---

<div class="menu-wrapper">

    <!-- Navegação Lateral (Desktop) / Top (Mobile) -->
    {categorias.length > 0 && (
        <aside class="menu-sidebar">
            <div class="sidebar-inner">
                <p class="sidebar-label">Categorias</p>
                <nav class="sidebar-nav">
                    {categorias.map((cat, i) => {
                        const meta = getMeta(cat);
                        return (
                            <a 
                                href={`#cat-${cat.toLowerCase().replace(/\s+/g, '-')}`}
                                class="sidebar-link"
                                data-cat={cat}
                                style={`--accent: ${meta.cor}`}
                            >
                                <span class="sidebar-emoji">{meta.emoji}</span>
                                <span class="sidebar-text">{cat}</span>
                                <span class="sidebar-dot"></span>
                            </a>
                        );
                    })}
                </nav>
            </div>
        </aside>
    )}

    <!-- Conteúdo do Menu -->
    <div class="menu-content">
        {categorias.map((cat, catIndex) => {
            const meta = getMeta(cat);
            const produtos = rawItems.filter((i: any) => {
                const attr = i.attributes || i;
                return (attr.Categoria || attr.CATEGORIA) === cat;
            });

            return (
                <section 
                    id={`cat-${cat.toLowerCase().replace(/\s+/g, '-')}`}
                    class="menu-section"
                    data-index={catIndex}
                >
                    <!-- Header da Categoria -->
                    <div class="cat-header" style={`--accent: ${meta.cor}`}>
                        <div class="cat-header-left">
                            <span class="cat-emoji">{meta.emoji}</span>
                            <div>
                                <h2 class="cat-title">{cat}</h2>
                                <p class="cat-count">{produtos.length} {produtos.length === 1 ? 'item' : 'itens'}</p>
                            </div>
                        </div>
                        <div class="cat-line"></div>
                    </div>

                    <!-- Grid de Produtos -->
                    <div class="produtos-grid">
                        {produtos.map((item: any, itemIndex: number) => {
                            const data = item.attributes || item;
                            const Nome = data.Nome || data.NOME || '';
                            const Preco = data.Preco || data.PRECO || '';
                            const Descricao = data.Descricao || data.DESCRICAO || '';

                            return (
                                <div 
                                    class="produto-card"
                                    style={`--accent: ${meta.cor}; animation-delay: ${itemIndex * 60}ms`}
                                >
                                    <div class="produto-top">
                                        <h3 class="produto-nome">{Nome}</h3>
                                        <div class="produto-preco-wrap">
                                            <span class="produto-preco">{Preco}<span class="preco-euro">€</span></span>
                                        </div>
                                    </div>
                                    {Descricao && (
                                        <p class="produto-desc">{Descricao}</p>
                                    )}
                                    <div class="produto-accent-bar"></div>
                                </div>
                            );
                        })}
                    </div>
                </section>
            );
        })}
    </div>

</div>

<style>
    /* ── Layout Geral ── */
    .menu-wrapper {
        display: flex;
        gap: 0;
        min-height: 100vh;
        align-items: flex-start;
    }

    /* ── Sidebar ── */
    .menu-sidebar {
        width: 220px;
        flex-shrink: 0;
        position: sticky;
        top: 120px;
        max-height: calc(100vh - 140px);
        overflow-y: auto;
        padding: 2rem 1.5rem 2rem 2rem;
        scrollbar-width: none;
    }
    .menu-sidebar::-webkit-scrollbar { display: none; }

    .sidebar-inner { position: relative; }

    .sidebar-label {
        font-family: 'Lato', sans-serif;
        font-size: 0.6rem;
        font-weight: 400;
        letter-spacing: 0.35em;
        text-transform: uppercase;
        color: var(--canela);
        margin-bottom: 1.5rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid rgba(192,125,62,0.2);
    }

    .sidebar-nav {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .sidebar-link {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.6rem 0.75rem;
        border-radius: 8px;
        text-decoration: none;
        transition: all 0.25s ease;
        position: relative;
        group: true;
    }

    .sidebar-link:hover,
    .sidebar-link.active {
        background: rgba(192,125,62,0.1);
    }

    .sidebar-link.active .sidebar-text {
        color: var(--accent, var(--canela));
        font-weight: 400;
    }

    .sidebar-link.active .sidebar-dot {
        opacity: 1;
        background: var(--accent, var(--canela));
    }

    .sidebar-emoji {
        font-size: 1rem;
        width: 1.5rem;
        text-align: center;
        flex-shrink: 0;
    }

    .sidebar-text {
        font-family: 'Lato', sans-serif;
        font-size: 0.78rem;
        font-weight: 300;
        letter-spacing: 0.08em;
        color: var(--text-light);
        transition: color 0.2s;
        flex: 1;
    }

    .sidebar-link:hover .sidebar-text {
        color: var(--accent, var(--canela));
    }

    .sidebar-dot {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: var(--accent, var(--canela));
        opacity: 0;
        transition: opacity 0.2s;
        flex-shrink: 0;
    }

    .sidebar-link:hover .sidebar-dot {
        opacity: 0.5;
    }

    /* ── Divisor Vertical ── */
    .menu-sidebar::after {
        content: '';
        position: absolute;
        right: 0;
        top: 2rem;
        bottom: 2rem;
        width: 1px;
        background: linear-gradient(to bottom, transparent, rgba(192,125,62,0.2) 20%, rgba(192,125,62,0.2) 80%, transparent);
    }
    .menu-sidebar { position: sticky; top: 120px; }

    /* ── Conteúdo ── */
    .menu-content {
        flex: 1;
        padding: 3rem 3rem 6rem 3rem;
        max-width: 900px;
    }

    /* ── Seção de Categoria ── */
    .menu-section {
        margin-bottom: 5rem;
        scroll-margin-top: 130px;
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.6s ease, transform 0.6s ease;
    }

    .menu-section.visible {
        opacity: 1;
        transform: translateY(0);
    }

    /* ── Header da Categoria ── */
    .cat-header {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .cat-header-left {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-shrink: 0;
    }

    .cat-emoji {
        font-size: 2rem;
        width: 3rem;
        height: 3rem;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255,255,255,0.9);
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.08);
        flex-shrink: 0;
    }

    .cat-title {
        font-family: 'Cinzel', serif;
        font-size: 1.4rem;
        font-weight: 600;
        color: var(--choc);
        letter-spacing: 0.08em;
        line-height: 1;
        margin-bottom: 0.2rem;
        text-transform: uppercase;
    }

    .cat-count {
        font-family: 'Lato', sans-serif;
        font-size: 0.65rem;
        font-weight: 300;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: var(--accent, var(--canela));
    }

    .cat-line {
        flex: 1;
        height: 1px;
        background: linear-gradient(to right, rgba(192,125,62,0.3), transparent);
    }

    /* ── Grid de Produtos ── */
    .produtos-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
    }

    /* ── Card de Produto ── */
    .produto-card {
        background: #fff;
        border-radius: 12px;
        padding: 1.25rem 1.5rem 1rem;
        border: 1px solid rgba(232,221,208,0.8);
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
        cursor: default;
        opacity: 0;
        animation: cardIn 0.5s ease forwards;
    }

    @keyframes cardIn {
        from { opacity: 0; transform: translateY(12px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .produto-card:hover {
        border-color: var(--accent, var(--canela));
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        transform: translateY(-2px);
    }

    .produto-card:hover .produto-accent-bar {
        width: 100%;
    }

    .produto-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        margin-bottom: 0.5rem;
    }

    .produto-nome {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.1rem;
        font-weight: 500;
        color: var(--choc);
        line-height: 1.3;
        flex: 1;
        transition: color 0.2s;
    }

    .produto-card:hover .produto-nome {
        color: var(--accent, var(--canela));
    }

    .produto-preco-wrap {
        flex-shrink: 0;
    }

    .produto-preco {
        font-family: 'Cinzel', serif;
        font-size: 1rem;
        font-weight: 600;
        color: var(--choc);
        white-space: nowrap;
        display: flex;
        align-items: baseline;
        gap: 1px;
    }

    .preco-euro {
        font-size: 0.65rem;
        font-weight: 400;
        color: var(--canela);
        margin-left: 1px;
    }

    .produto-desc {
        font-family: 'Cormorant Garamond', serif;
        font-size: 0.85rem;
        font-style: italic;
        color: var(--text-light);
        line-height: 1.5;
        opacity: 0.8;
    }

    .produto-accent-bar {
        position: absolute;
        bottom: 0;
        left: 0;
        height: 2px;
        width: 0;
        background: var(--accent, var(--canela));
        transition: width 0.4s ease;
        border-radius: 0 0 12px 12px;
    }

    /* ── Responsivo ── */
    @media (max-width: 900px) {
        .menu-sidebar { display: none; }
        .menu-content { padding: 2rem 1.5rem 4rem; }
    }

    @media (max-width: 640px) {
        .produtos-grid { grid-template-columns: 1fr; }
        .menu-content { padding: 1.5rem 1rem 4rem; }
        .cat-title { font-size: 1.1rem; }
    }
</style>

<!-- Barra de navegação mobile (scroll horizontal) -->
{categorias.length > 0 && (
    <div class="mobile-nav" id="mobileNav">
        {categorias.map(cat => {
            const meta = getMeta(cat);
            return (
                <a 
                    href={`#cat-${cat.toLowerCase().replace(/\s+/g, '-')}`}
                    class="mobile-nav-item"
                    data-cat={cat}
                    style={`--accent: ${meta.cor}`}
                >
                    <span>{meta.emoji}</span>
                    <span>{cat}</span>
                </a>
            );
        })}
    </div>
)}

<style>
    .mobile-nav {
        display: none;
        position: sticky;
        top: 72px;
        z-index: 50;
        background: rgba(247,240,230,0.95);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(192,125,62,0.15);
        padding: 0.75rem 1rem;
        overflow-x: auto;
        gap: 0.5rem;
        scrollbar-width: none;
        -webkit-overflow-scrolling: touch;
    }
    .mobile-nav::-webkit-scrollbar { display: none; }

    @media (max-width: 900px) {
        .mobile-nav { display: flex; }
    }

    .mobile-nav-item {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.4rem 0.9rem;
        border-radius: 999px;
        background: white;
        border: 1px solid rgba(232,221,208,0.8);
        font-family: 'Lato', sans-serif;
        font-size: 0.7rem;
        font-weight: 300;
        letter-spacing: 0.1em;
        color: var(--choc);
        text-decoration: none;
        white-space: nowrap;
        transition: all 0.2s;
        flex-shrink: 0;
    }

    .mobile-nav-item:hover,
    .mobile-nav-item.active {
        background: var(--accent, var(--canela));
        color: white;
        border-color: var(--accent, var(--canela));
    }
</style>

<script>
    // Scroll reveal para seções
    const sections = document.querySelectorAll('.menu-section');
    const sectionObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('visible');
            }
        });
    }, { threshold: 0.05, rootMargin: '0px 0px -50px 0px' });

    sections.forEach(s => sectionObserver.observe(s));

    // Highlight da sidebar e mobile nav ao scroll
    const sidebarLinks = document.querySelectorAll('.sidebar-link, .mobile-nav-item');

    const highlightObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const id = entry.target.id;
                const cat = id.replace('cat-', '');
                
                sidebarLinks.forEach(link => {
                    link.classList.remove('active');
                    const href = link.getAttribute('href') || '';
                    if (href.includes(cat)) {
                        link.classList.add('active');
                        // Scroll mobile nav to show active item
                        if (link.closest('.mobile-nav')) {
                            link.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
                        }
                    }
                });
            }
        });
    }, { threshold: 0.3, rootMargin: '-100px 0px -60% 0px' });

    sections.forEach(s => highlightObserver.observe(s));
</script>