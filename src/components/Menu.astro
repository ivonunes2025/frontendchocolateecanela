---
import axios from 'axios';

interface Produto {
    id: number;
    Nome: string;
    Categoria: string;
    Preco: number | string;
    Descricao?: string;
}

const strapiUrl = "http://localhost:1337";
let rawItems: any[] = [];
let categorias: string[] = [];

try {
    // Aumentamos o limite para 100 para garantir que todos os produtos (Crepes, Waffles, etc) sejam carregados
    const response = await axios.get(`${strapiUrl}/api/produto-menus?populate=*&pagination[pageSize]=100`);
    rawItems = response.data.data;
    
    // Helper para extrair atributos tanto de Strapi v4 (com .attributes) como v5 (plano)
    const getAttr = (item: any) => {
        if (!item) return {};
        const data = item.attributes || item;
        return {
            Nome: data.Nome || data.NOME,
            Categoria: data.Categoria || data.CATEGORIA,
            Preco: data.Preco || data.PRECO,
            Descricao: data.Descricao || data.DESCRICAO
        };
    };
    
    // Pegar categorias únicas e garantir que estão limpas e ordenadas
    const allCats = rawItems.map((item: any) => getAttr(item).Categoria);
    categorias = [...new Set(allCats)]
        .filter((cat): cat is string => typeof cat === 'string' && cat.trim() !== '')
        .sort((a, b) => a.localeCompare(b, 'pt'));
} catch (error: any) {
    console.error("Erro ao ligar ao Strapi. O Strapi está a correr?", error.message);
}

// Mapeamento de Emojis e Imagens para Categorias
const catMeta: Record<string, { emoji: string; img: string }> = {
    'Cafetaria': { emoji: '☕', img: 'https://images.unsplash.com/photo-1509042239860-f550ce710b93?w=800&q=80' },
    'Crepes': { emoji: '🥞', img: 'https://images.unsplash.com/photo-1519676867240-f03562e64548?w=800&q=80' },
    'Waffles': { emoji: '🧇', img: 'https://images.unsplash.com/photo-1562329265-95a6d7a83440?w=800&q=80' },
    'Iogurtes': { emoji: '🥣', img: 'https://images.unsplash.com/photo-1488477181946-6428a0291777?w=800&q=80' },
    'Torradas': { emoji: '🍞', img: 'https://images.unsplash.com/photo-1525351484163-7529414344d8?w=800&q=80' },
    'Tostas': { emoji: '🥪', img: 'https://images.unsplash.com/photo-1528735602780-2552fd46c7af?w=800&q=80' },
    'Sumos': { emoji: '🥤', img: 'https://images.unsplash.com/photo-1536599424071-0b215a388ba7?w=800&q=80' },
    'Bolos': { emoji: '🍰', img: 'https://images.unsplash.com/photo-1578985545062-69928b1d9587?w=800&q=80' },
    'Padaria': { emoji: '🥖', img: 'https://images.unsplash.com/photo-1509440159596-0249088772ff?w=800&q=80' },
};

const getMeta = (cat: string) => catMeta[cat] || { emoji: '✨', img: 'https://images.unsplash.com/photo-1555507036-ab1f4038808a?w=800&q=80' };
---

<section id="menu" class="max-w-6xl mx-auto px-6">
    
    {/* Navegação por Categorias - Estilo "Chips" Moderno */}
    {categorias.length > 0 && (
        <nav class="flex flex-wrap justify-center gap-3 mb-24 sticky top-24 z-20 bg-[var(--cream)]/80 backdrop-blur-md py-4 rounded-full px-6 shadow-sm border border-[var(--cream-dark)]">
            {categorias.map(cat => (
                <a 
                    href={`#${cat.toLowerCase().replace(/\s+/g, '-')}`}
                    class="px-5 py-2 bg-white text-[var(--choc)] hover:bg-[var(--canela)] hover:text-white transition-all duration-300 font-lato text-[0.65rem] uppercase tracking-widest rounded-full shadow-sm border border-[var(--cream-dark)] flex items-center gap-2 group"
                >
                    <span class="group-hover:scale-125 transition-transform">{getMeta(cat).emoji}</span>
                    {cat}
                </a>
            ))}
        </nav>
    )}

    <div class="space-y-32">
        {categorias.map((cat) => {
            const meta = getMeta(cat);

            return (
                <section id={cat.toLowerCase().replace(/\s+/g, '-')} class="scroll-mt-40 reveal">
                    <div class="flex flex-col lg:flex-row gap-12">
                        {/* Lateral Esquerda: Info da Categoria */}
                        <div class="lg:w-1/3">
                            <div class="sticky top-40">
                                <div class="relative mb-8 group inline-block">
                                    <div class="w-32 h-32 overflow-hidden rounded-2xl shadow-lg border-4 border-white rotate-3 group-hover:rotate-0 transition-transform duration-500">
                                        <img 
                                            src={meta.img} 
                                            alt={cat} 
                                            class="w-full h-full object-cover"
                                        />
                                    </div>
                                    <span class="absolute -bottom-4 -right-4 text-5xl drop-shadow-md">{meta.emoji}</span>
                                </div>
                                
                                <h2 class="font-cinzel text-4xl text-[var(--choc)] mb-4 uppercase tracking-tighter">
                                    {cat}
                                </h2>
                                <p class="font-serif italic text-lg text-[var(--canela)] leading-relaxed opacity-80">
                                    A nossa seleção de {cat.toLowerCase()}, preparada na hora para si.
                                </p>
                                <div class="mt-8 h-1 w-12 bg-[var(--canela)] rounded-full opacity-30"></div>
                            </div>
                        </div>

                        {/* Lateral Direita: Grelha de Produtos (2 colunas) */}
                        <div class="lg:w-2/3">
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                {rawItems
                                    .filter((i: any) => {
                                        const attr = i.attributes || i;
                                        return (attr.Categoria || attr.CATEGORIA) === cat;
                                    })
                                    .map((item: any) => {
                                        const data = item.attributes || item;
                                        const Nome = data.Nome || data.NOME;
                                        const Preco = data.Preco || data.PRECO;
                                        const Descricao = data.Descricao || data.DESCRICAO;

                                        return (
                                            <div class="menu-item-row group p-4 rounded-xl hover:bg-white hover:shadow-md transition-all duration-300 border border-transparent hover:border-[var(--cream-dark)]">
                                                <div class="flex justify-between items-baseline gap-4">
                                                    <h3 class="font-serif text-xl text-[var(--choc)] group-hover:text-[var(--canela)] transition-colors">
                                                        {Nome}
                                                    </h3>
                                                    <div class="flex-1 border-b border-dotted border-[var(--cream-dark)] opacity-50 group-hover:opacity-100 transition-opacity"></div>
                                                    <span class="font-lato font-bold text-[var(--choc)]">
                                                        {Preco}€
                                                    </span>
                                                </div>
                                                {Descricao && (
                                                    <p class="text-[var(--text-light)] text-xs font-lato mt-2 leading-relaxed opacity-70 group-hover:opacity-100 transition-opacity">
                                                        {Descricao}
                                                    </p>
                                                )}
                                            </div>
                                        );
                                    })
                                }
                            </div>
                        </div>
                    </div>
                </section>
            );
        })}
    </div>

</section>

<style>
    .menu-item-row {
        display: flex;
        flex-direction: column;
    }

    .reveal {
        opacity: 0;
        transform: translateY(30px);
        transition: all 0.8s ease-out;
    }

    .reveal.active {
        opacity: 1;
        transform: translateY(0);
    }

    /* Ajuste para o scroll suave */
    :global(html) {
        scroll-padding-top: 120px;
    }
</style>

<script>
    // Animação de Scroll Reveal
    const revealElements = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('active');
            }
        });
    }, { threshold: 0.1 });

    revealElements.forEach(el => observer.observe(el));
</script>
