---
import axios from 'axios';

interface Produto {
    id: number;
    Nome: string;
    Categoria: string;
    Preco: number | string;
    Descricao?: string;
}

const strapiUrl = "http://localhost:1337";
let rawItems: any[] = [];
let categorias: string[] = [];
let categoryMetaMap: Record<string, { emoji: string; cor: string; imagem?: string }> = {};

// Fallback hardcoded (será mesclado com o CMS)
const defaultMeta: Record<string, { emoji: string; cor: string }> = {
    'Cafetaria':    { emoji: '☕', cor: '#8B5E3C' },
    'Pastelaria':   { emoji: '🥐', cor: '#D99E6A' },
    'Torradas':     { emoji: '🍞', cor: '#A0704C' },
    'Tostas':       { emoji: '🥪', cor: '#7A5C47' },
    'Baguetes':     { emoji: '🥖', cor: '#8B7355' },
    'Crepes':       { emoji: '🥞', cor: '#C07D3E' },
    'Waffles':      { emoji: '🧇', cor: '#B8722A' },
    'Panquecas':    { emoji: '🥞', cor: '#C07D3E' },
    'Panqueca':     { emoji: '🥞', cor: '#C07D3E' },
    'Iogurtes':     { emoji: '🥣', cor: '#9B7B5A' },
    'Iogurte':      { emoji: '🥣', cor: '#9B7B5A' },
    'Sumos':        { emoji: '🥤', cor: '#5E8B6E' },
    'Sumo':         { emoji: '🥤', cor: '#5E8B6E' },
    'Sumos Naturais':{ emoji: '🥤', cor: '#5E8B6E' },
    'Sumo Natural': { emoji: '🥤', cor: '#5E8B6E' },
    'Saladas':      { emoji: '🥗', cor: '#5E8B6E' },
    'Salada':       { emoji: '🥗', cor: '#5E8B6E' },
    'Bebidas':      { emoji: '🍹', cor: '#4A6E8B' },
    'Bolos':        { emoji: '🍰', cor: '#C07D3E' },
    'Padaria':      { emoji: '🥖', cor: '#8B7355' },
    'Gelados':      { emoji: '🍦', cor: '#9B7B5A' },
    'Sobremesas':   { emoji: '🍮', cor: '#C07D3E' },
};

try {
    // 1. Buscar Produtos
    const productsRes = await axios.get(`${strapiUrl}/api/produto-menus?populate=*&pagination[pageSize]=100`);
    rawItems = productsRes.data.data;
    
    // 2. Buscar Metadados de Categorias (Dinâmico do CMS)
    try {
        const catRes = await axios.get(`${strapiUrl}/api/categoria-menus?populate=*`);
        const catData = catRes.data.data;
        catData.forEach((item: any) => {
            const attr = item.attributes || item;
            let nome = attr.Nome || attr.NOME;
            if (nome) {
                nome = nome.trim();
                const imgData = attr.Imagem?.data?.attributes || attr.Imagem?.data;
                categoryMetaMap[nome] = {
                    emoji: attr.Emoji || '✨',
                    cor: attr.Cor || '#C07D3E',
                    imagem: imgData?.url ? (imgData.url.startsWith('http') ? imgData.url : `${strapiUrl}${imgData.url}`) : undefined
                };
            }
        });
    } catch (e) {
        // Silencioso: categoria-menus pode não existir ainda
    }

    const getAttr = (item: any) => {
        if (!item) return {};
        const data = item.attributes || item;
        return {
            Nome: data.Nome || data.NOME,
            Categoria: (data.Categoria || data.CATEGORIA || "").trim(),
            Preco: data.Preco || data.PRECO,
            Descricao: data.Descricao || data.DESCRICAO
        };
    };
    
    const allCats = rawItems.map((item: any) => getAttr(item).Categoria);
    categorias = [...new Set(allCats)]
        .filter((cat): cat is string => typeof cat === 'string' && cat !== '')
        .sort((a, b) => a.localeCompare(b, 'pt'));
} catch (error: any) {
    console.error("Erro ao ligar ao Strapi.", error.message);
}

const getMeta = (cat: string) => {
    const trimmedCat = cat.trim();
    // Tentar match exato no CMS primeiro
    if (categoryMetaMap[trimmedCat]) return categoryMetaMap[trimmedCat];
    
    // Tentar match no fallback (case-insensitive para segurança)
    const fallbackKey = Object.keys(defaultMeta).find(k => k.toLowerCase() === trimmedCat.toLowerCase());
    return (fallbackKey ? defaultMeta[fallbackKey] : null) || { emoji: '✨', cor: '#C07D3E' };
};
---

<div class="menu-wrapper">

    <!-- Navegação Lateral (Desktop) -->
    {categorias.length > 0 && (
        <aside class="menu-sidebar">
            <div class="sidebar-inner">
                <p class="sidebar-label">Categorias</p>
                <nav class="sidebar-nav">
                    {categorias.map((cat, i) => {
                        const meta = getMeta(cat);
                        return (
                            <a 
                                href={`#cat-${cat.toLowerCase().replace(/\s+/g, '-')}`}
                                class="sidebar-link"
                                data-cat={cat}
                                style={`--accent: ${meta.cor}`}
                            >
                                <span class="sidebar-emoji">{meta.emoji}</span>
                                <span class="sidebar-text">{cat}</span>
                                <span class="sidebar-dot"></span>
                            </a>
                        );
                    })}
                </nav>
            </div>
        </aside>
    )}

    <!-- Conteúdo do Menu -->
    <div class="menu-content">
        {categorias.map((cat, catIndex) => {
            const meta = getMeta(cat);
            const produtos = rawItems.filter((i: any) => {
                const attr = i.attributes || i;
                return (attr.Categoria || attr.CATEGORIA) === cat;
            });

            return (
                <section 
                    id={`cat-${cat.toLowerCase().replace(/\s+/g, '-')}`}
                    class="menu-section reveal"
                >
                    <!-- Header da Categoria -->
                    <div class="cat-header" style={`--accent: ${meta.cor}`}>
                        <div class="cat-header-left">
                            <span class="cat-emoji-floating">{meta.emoji}</span>
                            <div>
                                <h2 class="cat-title">{cat}</h2>
                                <p class="cat-count">{produtos.length} {produtos.length === 1 ? 'item' : 'itens'}</p>
                            </div>
                        </div>
                        <div class="cat-line"></div>
                    </div>

                    <!-- Grid de Produtos -->
                    <div class="produtos-grid">
                        {produtos.map((item: any, itemIndex: number) => {
                            const data = item.attributes || item;
                            const Nome = data.Nome || data.NOME || '';
                            const Preco = data.Preco || data.PRECO || '';
                            const Descricao = data.Descricao || data.DESCRICAO || '';

                            return (
                                <div 
                                    class="produto-card glass"
                                    style={`--accent: ${meta.cor}; animation-delay: ${itemIndex * 60}ms`}
                                >
                                    <div class="produto-top">
                                        <h3 class="produto-nome">{Nome}</h3>
                                        <div class="produto-preco-wrap">
                                            <span class="produto-preco">{Preco}<span class="preco-euro">€</span></span>
                                        </div>
                                    </div>
                                    {Descricao && (
                                        <p class="produto-desc">{Descricao}</p>
                                    )}
                                    <div class="produto-accent-bar"></div>
                                </div>
                            );
                        })}
                    </div>
                </section>
            );
        })}
    </div>

</div>

<!-- Navegação Mobile -->
{categorias.length > 0 && (
    <div class="mobile-nav glass" id="mobileNav">
        {categorias.map(cat => {
            const meta = getMeta(cat);
            return (
                <a 
                    href={`#cat-${cat.toLowerCase().replace(/\s+/g, '-')}`}
                    class="mobile-nav-item"
                    data-cat={cat}
                    style={`--accent: ${meta.cor}`}
                >
                    <span class="mobile-emoji">{meta.emoji}</span>
                    <span>{cat}</span>
                </a>
            );
        })}
    </div>
)}

<style>
    /* ── Layout Geral ── */
    .menu-wrapper {
        display: flex;
        gap: 0;
        min-height: 100vh;
        align-items: flex-start;
        position: relative;
    }

    /* ── Sidebar ── */
    .menu-sidebar {
        width: 240px;
        flex-shrink: 0;
        position: sticky;
        top: 120px;
        max-height: calc(100vh - 140px);
        overflow-y: auto;
        padding: 2rem 1.5rem 2rem 2rem;
        scrollbar-width: none;
        z-index: 20;
    }
    .menu-sidebar::-webkit-scrollbar { display: none; }

    .sidebar-label {
        font-family: 'Lato', sans-serif;
        font-size: 0.6rem;
        font-weight: 300;
        letter-spacing: 0.4em;
        text-transform: uppercase;
        color: var(--canela);
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid rgba(192,125,62,0.15);
    }

    .sidebar-nav {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .sidebar-link {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 0.8rem 1rem;
        border-radius: 12px;
        text-decoration: none;
        transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);
        position: relative;
    }

    .sidebar-link:hover,
    .sidebar-link.active {
        background: rgba(255, 255, 255, 0.05);
        transform: translateX(5px);
    }

    .sidebar-link.active .sidebar-text {
        color: var(--accent, var(--canela));
        font-weight: 400;
    }

    .sidebar-emoji { font-size: 1.2rem; filter: grayscale(1) opacity(0.5); transition: all 0.3s; }
    .sidebar-link:hover .sidebar-emoji, .sidebar-link.active .sidebar-emoji { filter: none; opacity: 1; transform: scale(1.2); }

    .sidebar-text {
        font-family: 'Lato', sans-serif;
        font-size: 0.8rem;
        font-weight: 300;
        letter-spacing: 0.1em;
        color: var(--cream-dark);
        transition: color 0.3s;
    }

    .sidebar-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--accent, var(--canela));
        opacity: 0;
        transition: opacity 0.3s;
        margin-left: auto;
    }
    .sidebar-link.active .sidebar-dot { opacity: 1; box-shadow: 0 0 10px var(--accent); }

    /* ── Conteúdo ── */
    .menu-content {
        flex: 1;
        padding: 4rem 4rem 8rem 2rem;
        max-width: 1000px;
    }

    /* ── Seção de Categoria ── */
    .menu-section {
        margin-bottom: 8rem;
        scroll-margin-top: 140px;
    }

    /* ── Header da Categoria ── */
    .cat-header {
        display: flex;
        align-items: center;
        gap: 2rem;
        margin-bottom: 3rem;
    }

    .cat-header-left {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .cat-emoji-floating {
        font-size: 2.8rem;
        filter: drop-shadow(0 4px 15px rgba(0,0,0,0.3));
        animation: float 4s ease-in-out infinite;
    }

    @keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
    }

    .cat-title {
        font-family: 'Cinzel', serif;
        font-size: clamp(1.8rem, 4vw, 2.8rem);
        color: var(--cream);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        line-height: 1;
        margin-bottom: 0.4rem;
    }

    .cat-count {
        font-family: 'Lato', sans-serif;
        font-size: 0.7rem;
        font-weight: 300;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: var(--canela);
    }

    .cat-line {
        flex: 1;
        height: 1px;
        background: linear-gradient(to right, rgba(192,125,62,0.4), transparent);
    }

    /* ── Grid de Produtos ── */
    .produtos-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
    }

    /* ── Card de Produto ── */
    .produto-card {
        padding: 1.8rem 2rem;
        border-radius: 20px;
        transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
        position: relative;
        overflow: hidden;
    }

    .produto-card:hover {
        transform: translateY(-5px);
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(192, 125, 62, 0.3);
    }

    .produto-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1.5rem;
        margin-bottom: 0.8rem;
    }

    .produto-nome {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.25rem;
        font-weight: 500;
        color: var(--cream);
        line-height: 1.3;
    }

    .produto-preco {
        font-family: 'Cinzel', serif;
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--canela-light);
        white-space: nowrap;
    }

    .preco-euro { font-size: 0.7em; margin-left: 2px; }

    .produto-desc {
        font-family: 'Cormorant Garamond', serif;
        font-size: 0.95rem;
        font-style: italic;
        color: var(--cream-dark);
        opacity: 0.6;
        line-height: 1.5;
    }

    .produto-accent-bar {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 0;
        height: 2px;
        background: var(--accent, var(--canela));
        transition: width 0.6s ease;
    }
    .produto-card:hover .produto-accent-bar { width: 100%; }

    /* ── Navegação Mobile ── */
    .mobile-nav {
        display: none;
        position: fixed;
        bottom: 2rem;
        left: 50%;
        transform: translateX(-50%);
        z-index: 100;
        padding: 0.8rem;
        border-radius: 100px;
        gap: 0.5rem;
        max-width: 90vw;
        overflow-x: auto;
        scrollbar-width: none;
        box-shadow: 0 10px 40px rgba(0,0,0,0.5);
    }
    .mobile-nav::-webkit-scrollbar { display: none; }

    .mobile-nav-item {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.6rem 1.2rem;
        border-radius: 100px;
        background: rgba(255,255,255,0.05);
        color: var(--cream);
        font-family: 'Lato', sans-serif;
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        text-decoration: none;
        white-space: nowrap;
        transition: all 0.3s;
        border: 1px solid rgba(255,255,255,0.05);
    }

    .mobile-nav-item.active {
        background: var(--accent, var(--canela));
        color: var(--choc);
        font-weight: 600;
        border-color: var(--accent);
    }

    .mobile-emoji { font-size: 1.1rem; }

    /* ── Responsividade ── */
    @media (max-width: 1024px) {
        .menu-sidebar { display: none; }
        .menu-content { padding: 4rem 2rem 10rem; }
        .mobile-nav { display: flex; }
    }

    @media (max-width: 768px) {
        .produtos-grid { grid-template-columns: 1fr; }
        .cat-emoji-floating { font-size: 2.22rem; }
    }

    /* Scroll Reveal */
    .reveal {
        opacity: 0;
        transform: translateY(30px);
        transition: all 0.8s cubic-bezier(0.23, 1, 0.32, 1);
    }
    .reveal.visible {
        opacity: 1;
        transform: translateY(0);
    }
</style>

<script>
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('visible');
            }
        });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // Active link highlighting
    const sections = document.querySelectorAll('.menu-section');
    const navLinks = document.querySelectorAll('.sidebar-link, .mobile-nav-item');

    window.addEventListener('scroll', () => {
        let current = '';
        sections.forEach(section => {
            const sectionTop = (section as HTMLElement).offsetTop;
            if (window.pageYOffset >= sectionTop - 200) {
                current = section.getAttribute('id') || '';
            }
        });

        navLinks.forEach(link => {
            link.classList.remove('active');
            if (link.getAttribute('href') === `#${current}`) {
                link.classList.add('active');
                if (link.classList.contains('mobile-nav-item')) {
                    link.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
                }
            }
        });
    });
</script>