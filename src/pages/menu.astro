---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import MenuComponent from "../components/Menu.astro";
---

<Layout title="Menu | Chocolate & Canela">
    <Navbar />

    <main class="menu-page">
        <!-- Hero do Menu -->
        <header class="menu-hero">
            <div class="menu-hero-inner">
                <p class="menu-eyebrow">Chocolate & Canela Gourmet</p>
                <h1 class="menu-title">O Nosso<br /><em>Menu</em></h1>
                <p class="menu-subtitle">
                    Artesanal · Gourmet · Feito com amor
                </p>
                <div class="menu-hero-divider"></div>
            </div>
        </header>

        <!-- Área do Menu (sidebar + conteúdo) -->
        <div class="menu-body">
            <MenuComponent />
        </div>
    </main>

    <Footer />
</Layout>

<style>
    .menu-page {
        background: var(--cream);
        min-height: 100vh;
    }

    /* ── Hero ── */
    .menu-hero {
        background: var(--choc);
        padding: 9rem 3rem 5rem;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    .menu-hero::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
            radial-gradient(
                ellipse 70% 80% at 50% 100%,
                rgba(192, 125, 62, 0.15) 0%,
                transparent 70%
            ),
            url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none'%3E%3Cg fill='%23c07d3e' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        pointer-events: none;
    }

    .menu-hero-inner {
        position: relative;
        z-index: 1;
        animation: heroFade 1s ease both;
    }

    @keyframes heroFade {
        from {
            opacity: 0;
            transform: translateY(16px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .menu-eyebrow {
        font-family: "Lato", sans-serif;
        font-size: 0.65rem;
        font-weight: 300;
        letter-spacing: 0.4em;
        text-transform: uppercase;
        color: var(--canela);
        margin-bottom: 1.5rem;
    }

    .menu-title {
        font-family: "Cinzel", serif;
        font-size: clamp(2.8rem, 7vw, 5.5rem);
        font-weight: 400;
        color: var(--cream);
        line-height: 1;
        letter-spacing: 0.05em;
        margin-bottom: 1.5rem;
    }

    .menu-title em {
        font-style: normal;
        color: var(--canela-light);
        display: block;
        font-size: 1.1em;
    }

    .menu-subtitle {
        font-family: "Cormorant Garamond", serif;
        font-size: 1.1rem;
        font-style: italic;
        color: rgba(247, 240, 230, 0.5);
        letter-spacing: 0.05em;
    }

    .menu-hero-divider {
        width: 60px;
        height: 1px;
        background: linear-gradient(
            90deg,
            transparent,
            var(--canela),
            transparent
        );
        margin: 2rem auto 0;
    }

    /* ── Body ── */
    .menu-body {
        background: var(--cream);
        position: relative;
    }
</style>
