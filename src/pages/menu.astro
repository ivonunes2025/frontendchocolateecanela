---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import MenuComponent from "../components/Menu.astro";

const STRAPI_URL = "http://localhost:1337";

let hero = {
    Titulo: "O Nosso Menu",
    Subtitulo: "Artesanal · Gourmet · Feito com amor",
    Tagline: "Chocolate & Canela Gourmet",
    Imagem_Fundo: null as any
};

try {
    const heroRes = await fetch(`${STRAPI_URL}/api/hero-principal?populate=*`);
    if (heroRes.ok) {
        const json = await heroRes.json();
        const data = json.data.attributes || json.data;
        if (data) hero = { ...hero, ...data };
    }
} catch (error) {
    console.error("Erro ao buscar Hero no Menu:", error);
}

const getImgUrl = (imgData: any) => {
	const data = imgData?.data?.attributes || imgData?.data || imgData;
	const url = data?.url;
	if (!url) return null;
	return url.startsWith('http') ? url : `${STRAPI_URL}${url}`;
};

const heroImg = getImgUrl(hero.Imagem_Fundo);
---

<Layout title="Menu | Chocolate & Canela">
    <Navbar />

    <main class="menu-page">
        <!-- Hero do Menu -->
        <header class="menu-hero" style={heroImg ? `background-image: linear-gradient(rgba(27, 13, 8, 0.8), rgba(27, 13, 8, 0.8)), url(${heroImg}); background-size: cover; background-position: center;` : ''}>
            <div class="menu-hero-inner">
                <p class="menu-eyebrow">{hero.Tagline}</p>
                <h1 class="menu-title" set:html={hero.Titulo.replace('&', '<em>&</em>')}></h1>
                <p class="menu-subtitle">{hero.Subtitulo}</p>
                <div class="menu-hero-divider"></div>
            </div>
        </header>

        <!-- Área do Menu (sidebar + conteúdo) -->
        <div class="menu-body">
            <MenuComponent />
        </div>
    </main>

    <Footer />
</Layout>

<style>
    .menu-page {
        min-height: 100vh;
    }

    /* ── Hero ── */
    .menu-hero {
        padding: 12rem 3rem 8rem;
        text-align: center;
        position: relative;
        overflow: hidden;
        background: var(--choc);
    }

    .menu-hero-inner {
        position: relative;
        z-index: 1;
        animation: heroFade 1s ease both;
    }

    @keyframes heroFade {
        from {
            opacity: 0;
            transform: translateY(16px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .menu-eyebrow {
        font-family: "Lato", sans-serif;
        font-size: 0.65rem;
        font-weight: 300;
        letter-spacing: 0.4em;
        text-transform: uppercase;
        color: var(--canela);
        margin-bottom: 1.5rem;
    }

    .menu-title {
        font-family: "Cinzel", serif;
        font-size: clamp(2.8rem, 7vw, 5.5rem);
        font-weight: 400;
        color: var(--cream);
        line-height: 1;
        letter-spacing: 0.05em;
        margin-bottom: 1.5rem;
    }

    :global(.menu-title em) {
        font-style: normal;
        color: var(--canela-light);
        display: block;
        font-size: 1.1em;
    }

    .menu-subtitle {
        font-family: "Cormorant Garamond", serif;
        font-size: 1.1rem;
        font-style: italic;
        color: rgba(247, 240, 230, 0.5);
        letter-spacing: 0.05em;
    }

    .menu-hero-divider {
        width: 60px;
        height: 1px;
        background: linear-gradient(
            90deg,
            transparent,
            var(--canela),
            transparent
        );
        margin: 2rem auto 0;
    }

    /* ── Body ── */
    .menu-body {
        position: relative;
    }
</style>
</style>
